{
  "name": "smart_pipeline_orchestrator",
  "version": "2.0.0",
  "description": "智能路由指挥官。接收任务后自动分析复杂度：简单任务直接分发给对应专家；复杂任务（涉及架构变更、安全敏感、多模块联动）自动启动四阶段严格流水线（设计->编码->红队->审计）。具备气闸舱隔离协议。",
  "tags": ["router", "orchestrator", "adaptive-pipeline", "multi-agent"],
  "input_schema": {
    "type": "object",
    "properties": {
      "user_request": {"type": "string", "description": "用户的原始需求"},
      "available_agents": {"type": "array", "items": {"type": "string"}, "description": "当前可用的下级智能体列表"}
    },
    "required": ["user_request"]
  },
  "entry_point": "SKILL.md",
  "capabilities": {
    "auto_routing": true,
    "complexity_analysis": true,
    "stateful_pipeline": true
  }
}